{
  "name": "locilandapp",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:rules",
    "test:rules": "firebase emulators:exec --only firestore,storage \"vitest run --config vitest.config.mjs\"",
    "test:rules:watch": "firebase emulators:exec --only firestore,storage \"vitest --config vitest.config.mjs\"",
    "audit": "npm audit --omit=dev --audit-level=moderate",
    "audit:runtime": "npm audit --omit=dev --audit-level=high",
    "audit:deps": "npm audit --audit-level=high",
    "audit:visual": "node scripts/visual-audit.js",
    "validate": "npm run typecheck && npm test && npm run audit:runtime && npm run audit:visual"
  },
  "dependencies": {
    "@expo-google-fonts/fredoka-one": "^0.2.3",
    "@expo-google-fonts/nunito": "^0.4.2",
    "@lottiefiles/dotlottie-react": "^0.13.5",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "@react-navigation/stack": "^7.8.10",
    "expo": "~54.0.34",
    "expo-auth-session": "~7.0.11",
    "expo-av": "~16.0.8",
    "expo-crypto": "~15.0.9",
    "expo-file-system": "~19.0.22",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-notifications": "~0.32.17",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-video": "~3.0.16",
    "expo-web-browser": "~15.0.11",
    "firebase": "^12.12.0",
    "lottie-react-native": "~7.3.1",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@types/node": "^22.15.0",
    "firebase-tools": "^14.0.0",
    "vitest": "^3.2.0"
  },
  "private": true
}
