rules_version = '2';

service cloud.firestore {
  match /databases/{db}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isNonEmptyString(value, maxSize) {
      return value is string && value.size() > 0 && value.size() <= maxSize;
    }

    function isOptionalTimestamp(fieldName) {
      return !request.resource.data.keys().hasAny([fieldName])
        || request.resource.data[fieldName] is timestamp;
    }

    function preservesOptionalField(fieldName) {
      return (
        !resource.data.keys().hasAny([fieldName])
        && !request.resource.data.keys().hasAny([fieldName])
      ) || (
        resource.data.keys().hasAny([fieldName])
        && request.resource.data.keys().hasAny([fieldName])
        && request.resource.data[fieldName] == resource.data[fieldName]
      );
    }

    function isValidAgeGroup(value) {
      return value in ['6-9', '10-14'];
    }

    function isValidAvatarEmoji(value) {
      return value is string && value.size() > 0 && value.size() <= 16;
    }

    function isValidLevelTitle(value) {
      return value is string && value.size() > 0 && value.size() <= 80;
    }

    function isValidLastActiveDate(value) {
      return (
        value is string
        && value.matches('^\\d{4}-\\d{2}-\\d{2}$')
      ) || value is timestamp;
    }

    function isValidXPEventId(value) {
      return value is string
        && value.size() > 0
        && value.size() <= 160
        && value.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function hasOnlyUserProfileFields() {
      return request.resource.data.keys().hasOnly([
        'uid',
        'displayName',
        'email',
        'avatarEmoji',
        'ageGroup',
        'xp',
        'level',
        'levelTitle',
        'streak',
        'bestStreak',
        'lastActiveDate',
        'createdAt',
        'updatedAt',
        'lastXPGrantAt'
      ]);
    }

    function hasRequiredUserProfileFields() {
      return request.resource.data.keys().hasAll([
        'uid',
        'displayName',
        'email',
        'avatarEmoji',
        'ageGroup',
        'xp',
        'level',
        'streak',
        'lastActiveDate'
      ]);
    }

    function isValidUserProfileShape(uid) {
      return hasOnlyUserProfileFields()
        && hasRequiredUserProfileFields()
        && request.resource.data.uid == uid
        && isNonEmptyString(request.resource.data.displayName, 40)
        && isNonEmptyString(request.resource.data.email, 254)
        && isValidAvatarEmoji(request.resource.data.avatarEmoji)
        && isValidAgeGroup(request.resource.data.ageGroup)
        && request.resource.data.xp is int
        && request.resource.data.xp >= 0
        && request.resource.data.xp <= 100000
        && request.resource.data.level is int
        && request.resource.data.level >= 1
        && request.resource.data.level <= 10
        && (
          !request.resource.data.keys().hasAny(['levelTitle'])
          || isValidLevelTitle(request.resource.data.levelTitle)
        )
        && request.resource.data.streak is int
        && request.resource.data.streak >= 0
        && request.resource.data.streak <= 3650
        && (
          !request.resource.data.keys().hasAny(['bestStreak'])
          || (
            request.resource.data.bestStreak is int
            && request.resource.data.bestStreak >= 0
            && request.resource.data.bestStreak <= 3650
          )
        )
        && isValidLastActiveDate(request.resource.data.lastActiveDate)
        && isOptionalTimestamp('createdAt')
        && isOptionalTimestamp('updatedAt')
        && isOptionalTimestamp('lastXPGrantAt');
    }

    function isValidUserProfileCreate(uid) {
      return isValidUserProfileShape(uid)
        && request.resource.data.xp == 0
        && request.resource.data.level == 1
        && request.resource.data.streak == 0
        && (
          !request.resource.data.keys().hasAny(['bestStreak'])
          || request.resource.data.bestStreak == 0
        )
        && !request.resource.data.keys().hasAny(['lastXPGrantAt']);
    }

    function onlyEditableUserProfileFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'displayName',
        'avatarEmoji',
        'ageGroup',
        'updatedAt'
      ]);
    }

    function preservesCalculatedUserProfileFields() {
      return request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.xp == resource.data.xp
        && request.resource.data.level == resource.data.level
        && request.resource.data.streak == resource.data.streak
        && request.resource.data.lastActiveDate == resource.data.lastActiveDate
        && preservesOptionalField('levelTitle')
        && preservesOptionalField('bestStreak')
        && preservesOptionalField('createdAt')
        && preservesOptionalField('lastXPGrantAt');
    }

    function isValidUserProfileUpdate(uid) {
      return isValidUserProfileShape(uid)
        && onlyEditableUserProfileFieldsChanged()
        && preservesCalculatedUserProfileFields();
    }

    function xpDelta() {
      return request.resource.data.xp - resource.data.xp;
    }

    function isAllowedXPDelta(value) {
      return value == 10
        || value == 20
        || value == 25
        || value == 50
        || value == 100
        || (
          value > 0
          && value <= 500
        );
    }

    function isValidUserXPUpdate(uid) {
      return resource.data.uid == uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.displayName == resource.data.displayName
        && request.resource.data.avatarEmoji == resource.data.avatarEmoji
        && request.resource.data.ageGroup == resource.data.ageGroup
        && request.resource.data.streak == resource.data.streak
        && request.resource.data.lastActiveDate == resource.data.lastActiveDate
        && preservesOptionalField('bestStreak')
        && preservesOptionalField('createdAt')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'xp',
          'level',
          'levelTitle',
          'updatedAt',
          'lastXPGrantAt'
        ])
        && resource.data.xp is int
        && request.resource.data.xp is int
        && request.resource.data.xp > resource.data.xp
        && request.resource.data.xp <= 100000
        && isAllowedXPDelta(xpDelta())
        && resource.data.level is int
        && request.resource.data.level is int
        && request.resource.data.level >= resource.data.level
        && request.resource.data.level >= 1
        && request.resource.data.level <= 10
        && isValidLevelTitle(request.resource.data.levelTitle)
        && isOptionalTimestamp('updatedAt')
        && isOptionalTimestamp('lastXPGrantAt');
    }

    function isValidUserStreakUpdate(uid) {
      return resource.data.uid == uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.displayName == resource.data.displayName
        && request.resource.data.avatarEmoji == resource.data.avatarEmoji
        && request.resource.data.ageGroup == resource.data.ageGroup
        && request.resource.data.xp == resource.data.xp
        && request.resource.data.level == resource.data.level
        && preservesOptionalField('levelTitle')
        && preservesOptionalField('createdAt')
        && preservesOptionalField('lastXPGrantAt')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'streak',
          'bestStreak',
          'lastActiveDate',
          'updatedAt'
        ])
        && request.resource.data.streak is int
        && request.resource.data.streak >= 0
        && request.resource.data.streak <= 3650
        && request.resource.data.bestStreak is int
        && request.resource.data.bestStreak >= request.resource.data.streak
        && request.resource.data.bestStreak <= 3650
        && isValidLastActiveDate(request.resource.data.lastActiveDate)
        && isOptionalTimestamp('updatedAt');
    }

    function isValidXPReasonAmount(reason, amount) {
      return (
          reason == 'create_palace'
          && amount == 25
        ) || (
          reason == 'add_station'
          && amount == 10
        ) || (
          reason == 'complete_review'
          && amount == 20
        ) || (
          reason == 'perfect_review'
          && amount == 50
        ) || (
          reason == 'seven_day_streak'
          && amount == 100
        ) || (
          reason == 'achievement'
          && amount > 0
          && amount <= 500
        );
    }

    function hasOnlyXPEventFields() {
      return request.resource.data.keys().hasOnly([
        'eventId',
        'userId',
        'reason',
        'amount',
        'previousXP',
        'newXP',
        'previousLevel',
        'newLevel',
        'levelTitle',
        'leveledUp',
        'metadata',
        'createdAt'
      ]);
    }

    function isValidXPEventCreate(uid, eventId) {
      return hasOnlyXPEventFields()
        && request.resource.data.eventId == eventId
        && request.resource.data.userId == uid
        && isValidXPEventId(request.resource.data.eventId)
        && request.resource.data.reason is string
        && request.resource.data.amount is int
        && request.resource.data.amount > 0
        && request.resource.data.amount <= 500
        && isValidXPReasonAmount(
          request.resource.data.reason,
          request.resource.data.amount
        )
        && request.resource.data.previousXP is int
        && request.resource.data.previousXP >= 0
        && request.resource.data.newXP is int
        && request.resource.data.newXP == request.resource.data.previousXP + request.resource.data.amount
        && request.resource.data.newXP <= 100000
        && request.resource.data.previousLevel is int
        && request.resource.data.previousLevel >= 1
        && request.resource.data.previousLevel <= 10
        && request.resource.data.newLevel is int
        && request.resource.data.newLevel >= 1
        && request.resource.data.newLevel <= 10
        && request.resource.data.newLevel >= request.resource.data.previousLevel
        && isValidLevelTitle(request.resource.data.levelTitle)
        && request.resource.data.leveledUp is bool
        && (
          !request.resource.data.keys().hasAny(['metadata'])
          || request.resource.data.metadata is map
        )
        && isOptionalTimestamp('createdAt');
    }

    function isValidPalaceTemplateId(value) {
      return value in [
        'my-home',
        'magic-castle',
        'enchanted-forest',
        'space-station',
        'underwater-world',
        'dinosaur-island'
      ];
    }

    function hasOnlyPalaceFields() {
      return request.resource.data.keys().hasOnly([
        'userId',
        'name',
        'templateId',
        'stationCount',
        'createdAt',
        'updatedAt'
      ]);
    }

    function hasRequiredPalaceFields() {
      return request.resource.data.keys().hasAll([
        'userId',
        'name',
        'templateId',
        'stationCount',
        'createdAt'
      ]);
    }

    function isValidPalaceName(value) {
      return value is string
        && value.size() > 0
        && value.size() <= 40;
    }

    function isValidPalaceStationCount(value) {
      return value is int
        && value >= 0
        && value <= 20;
    }

    function isValidPalaceShape(uid) {
      return hasOnlyPalaceFields()
        && hasRequiredPalaceFields()
        && request.resource.data.userId == uid
        && isValidPalaceName(request.resource.data.name)
        && isValidPalaceTemplateId(request.resource.data.templateId)
        && isValidPalaceStationCount(request.resource.data.stationCount)
        && request.resource.data.createdAt is timestamp
        && isOptionalTimestamp('updatedAt');
    }

    function isValidPalaceCreate(uid) {
      return isValidPalaceShape(uid)
        && request.resource.data.stationCount == 0;
    }

    function onlyEditablePalaceFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'name',
        'stationCount',
        'updatedAt'
      ]);
    }

    function preservesImmutablePalaceFields() {
      return request.resource.data.userId == resource.data.userId
        && request.resource.data.templateId == resource.data.templateId
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function isValidPalaceStationCountTransition() {
      return request.resource.data.stationCount == resource.data.stationCount
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'stationCount',
            'updatedAt'
          ])
          && (
            request.resource.data.stationCount == resource.data.stationCount + 1
            || request.resource.data.stationCount == resource.data.stationCount - 1
          )
        );
    }

    function isValidPalaceUpdate(uid) {
      return isValidPalaceShape(uid)
        && resource.data.userId == uid
        && onlyEditablePalaceFieldsChanged()
        && preservesImmutablePalaceFields()
        && isValidPalaceStationCountTransition();
    }

    function hasValidOptionalImageUri() {
      return !request.resource.data.keys().hasAny(['imageUri'])
        || (
          request.resource.data.imageUri is string
          && request.resource.data.imageUri.size() <= 2048
          && request.resource.data.imageUri.matches('https://firebasestorage.googleapis.com/.*')
        );
    }

    function isValidStation(uid, palaceId) {
      return request.resource.data.keys().hasOnly([
          'id',
          'palaceId',
          'userId',
          'order',
          'emoji',
          'label',
          'memoryText',
          'imageUri',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.userId == uid
        && request.resource.data.palaceId == palaceId
        && request.resource.data.order is int
        && request.resource.data.order >= 0
        && request.resource.data.order <= 20
        && request.resource.data.emoji is string
        && request.resource.data.emoji.size() > 0
        && request.resource.data.emoji.size() <= 16
        && request.resource.data.label is string
        && request.resource.data.label.size() > 0
        && request.resource.data.label.size() <= 40
        && request.resource.data.memoryText is string
        && request.resource.data.memoryText.size() <= 500
        && request.resource.data.createdAt is timestamp
        && isOptionalTimestamp('updatedAt')
        && hasValidOptionalImageUri();
    }

    function isValidReviewSessionCreate(uid, palaceId) {
      return request.resource.data.keys().hasOnly([
          'palaceId',
          'userId',
          'startedAt',
          'completedAt',
          'totalStations',
          'correctAnswers',
          'incorrectAnswers',
          'xpEarned',
          'xpAppliedToUser',
          'xpAppliedAt',
          'isPerfect',
          'status',
          'updatedAt'
        ])
        && request.resource.data.userId == uid
        && request.resource.data.palaceId == palaceId
        && request.resource.data.startedAt is timestamp
        && request.resource.data.completedAt == null
        && request.resource.data.totalStations is int
        && request.resource.data.totalStations >= 2
        && request.resource.data.totalStations <= 21
        && request.resource.data.correctAnswers == 0
        && request.resource.data.incorrectAnswers == 0
        && request.resource.data.xpEarned == 0
        && request.resource.data.xpAppliedToUser == false
        && (
          !request.resource.data.keys().hasAny(['xpAppliedAt'])
          || request.resource.data.xpAppliedAt == null
        )
        && (
          !request.resource.data.keys().hasAny(['isPerfect'])
          || request.resource.data.isPerfect == false
        )
        && request.resource.data.status == 'active'
        && isOptionalTimestamp('updatedAt');
    }

    function hasValidReviewXpAppliedFlag() {
      return !request.resource.data.keys().hasAny(['xpAppliedToUser'])
        || request.resource.data.xpAppliedToUser is bool;
    }

    function isValidReviewSessionUpdate(uid, palaceId) {
      return request.resource.data.keys().hasOnly([
          'palaceId',
          'userId',
          'startedAt',
          'completedAt',
          'totalStations',
          'correctAnswers',
          'incorrectAnswers',
          'xpEarned',
          'xpAppliedToUser',
          'xpAppliedAt',
          'isPerfect',
          'status',
          'updatedAt'
        ])
        && resource.data.userId == uid
        && resource.data.palaceId == palaceId
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.palaceId == resource.data.palaceId
        && request.resource.data.startedAt == resource.data.startedAt
        && request.resource.data.totalStations == resource.data.totalStations
        && request.resource.data.correctAnswers is int
        && request.resource.data.incorrectAnswers is int
        && request.resource.data.correctAnswers >= 0
        && request.resource.data.incorrectAnswers >= 0
        && request.resource.data.correctAnswers <= request.resource.data.totalStations
        && request.resource.data.incorrectAnswers <= request.resource.data.totalStations
        && request.resource.data.correctAnswers + request.resource.data.incorrectAnswers <= request.resource.data.totalStations
        && request.resource.data.xpEarned is int
        && request.resource.data.xpEarned >= 0
        && request.resource.data.xpEarned <= 1000
        && hasValidReviewXpAppliedFlag()
        && (
          !request.resource.data.keys().hasAny(['xpAppliedAt'])
          || request.resource.data.xpAppliedAt == null
          || request.resource.data.xpAppliedAt is timestamp
        )
        && (
          !request.resource.data.keys().hasAny(['isPerfect'])
          || request.resource.data.isPerfect is bool
        )
        && isOptionalTimestamp('updatedAt')
        && request.resource.data.status in ['active', 'completed']
        && (
          request.resource.data.status == 'active'
            ? request.resource.data.completedAt == null
            : request.resource.data.completedAt is timestamp
        )
        && (
          request.resource.data.status == 'active'
            ? (
              request.resource.data.xpEarned == 0
              && request.resource.data.xpAppliedToUser == false
            )
            : true
        );
    }

    function isValidReviewAnswer(uid, palaceId, sessionId) {
      return request.resource.data.keys().hasOnly([
          'sessionId',
          'stationId',
          'correct',
          'answeredAt'
        ])
        && request.resource.data.sessionId == sessionId
        && request.resource.data.stationId is string
        && request.resource.data.stationId.size() > 0
        && exists(
          /databases/$(db)/documents/users/$(uid)/palaces/$(palaceId)/stations/$(request.resource.data.stationId)
        )
        && request.resource.data.correct is bool
        && request.resource.data.answeredAt is timestamp;
    }

    function isValidAchievementWrite(uid, achievementId) {
      return request.resource.data.keys().hasOnly([
          'id',
          'achievementId',
          'title',
          'description',
          'emoji',
          'xpReward',
          'earnedAt',
          'createdAt',
          'unlockedAt',
          'triggerType',
          'xpEventId'
        ])
        && (
          !request.resource.data.keys().hasAny(['id'])
          || request.resource.data.id == achievementId
        )
        && (
          !request.resource.data.keys().hasAny(['achievementId'])
          || request.resource.data.achievementId == achievementId
        )
        && (
          !request.resource.data.keys().hasAny(['title'])
          || isNonEmptyString(request.resource.data.title, 80)
        )
        && (
          !request.resource.data.keys().hasAny(['description'])
          || request.resource.data.description is string
        )
        && (
          !request.resource.data.keys().hasAny(['emoji'])
          || isValidAvatarEmoji(request.resource.data.emoji)
        )
        && (
          !request.resource.data.keys().hasAny(['xpReward'])
          || (
            request.resource.data.xpReward is int
            && request.resource.data.xpReward >= 0
            && request.resource.data.xpReward <= 500
          )
        )
        && (
          !request.resource.data.keys().hasAny(['triggerType'])
          || request.resource.data.triggerType is string
        )
        && (
          !request.resource.data.keys().hasAny(['xpEventId'])
          || isValidXPEventId(request.resource.data.xpEventId)
        )
        && isOptionalTimestamp('earnedAt')
        && isOptionalTimestamp('createdAt')
        && isOptionalTimestamp('unlockedAt');
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && isValidUserProfileCreate(uid);
      allow update: if isOwner(uid)
        && (
          isValidUserProfileUpdate(uid)
          || isValidUserXPUpdate(uid)
          || isValidUserStreakUpdate(uid)
        );
      allow delete: if false;

      match /xpEvents/{eventId} {
        allow read: if isOwner(uid);

        allow create: if isOwner(uid)
          && !exists(/databases/$(db)/documents/users/$(uid)/xpEvents/$(eventId))
          && isValidXPEventCreate(uid, eventId);

        allow update, delete: if false;
      }

      match /achievements/{achievementId} {
        allow read: if isOwner(uid);

        allow create, update: if isOwner(uid)
          && isValidAchievementWrite(uid, achievementId);

        allow delete: if false;
      }

      match /palaces/{palaceId} {
        allow read: if isOwner(uid);

        allow create: if isOwner(uid)
          && isValidPalaceCreate(uid);

        allow update: if isOwner(uid)
          && isValidPalaceUpdate(uid);

        allow delete: if isOwner(uid)
          && resource.data.userId == uid;

        match /stations/{stationId} {
          allow read: if isOwner(uid);

          allow create: if isOwner(uid)
            && isValidStation(uid, palaceId);

          allow update: if isOwner(uid)
            && resource.data.userId == uid
            && resource.data.palaceId == palaceId
            && isValidStation(uid, palaceId);

          allow delete: if isOwner(uid)
            && resource.data.userId == uid
            && resource.data.palaceId == palaceId;
        }

        match /reviewSessions/{sessionId} {
          allow read: if isOwner(uid);

          allow create: if isOwner(uid)
            && isValidReviewSessionCreate(uid, palaceId);

          allow update: if isOwner(uid)
            && isValidReviewSessionUpdate(uid, palaceId);

          allow delete: if false;

          match /answers/{answerId} {
            allow read: if isOwner(uid);

            allow create, update: if isOwner(uid)
              && exists(
                /databases/$(db)/documents/users/$(uid)/palaces/$(palaceId)/reviewSessions/$(sessionId)
              )
              && isValidReviewAnswer(uid, palaceId, sessionId);

            allow delete: if false;
          }
        }
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}