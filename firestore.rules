rules_version = '2';

service cloud.firestore {
  match /databases/{db}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function isNonEmptyString(value, maxSize) {
      return value is string && value.size() > 0 && value.size() <= maxSize;
    }

    function isOptionalTimestamp(fieldName) {
      return !request.resource.data.keys().hasAny([fieldName])
        || request.resource.data[fieldName] is timestamp;
    }

    function isValidAgeGroup(value) {
      return value in ['6-9', '10-14'];
    }

    function isValidAvatarEmoji(value) {
      return value is string && value.size() > 0 && value.size() <= 16;
    }

    function isValidLevelTitle(value) {
      return value is string && value.size() > 0 && value.size() <= 80;
    }

    function isValidLastActiveDate(value) {
      return (
        value is string
        && value.matches('^\\d{4}-\\d{2}-\\d{2}$')
      ) || value is timestamp;
    }

    function expectedLevelFromXP(xp) {
      return xp >= 5000 ? 10
        : xp >= 3500 ? 9
        : xp >= 2700 ? 8
        : xp >= 2000 ? 7
        : xp >= 1400 ? 6
        : xp >= 900 ? 5
        : xp >= 500 ? 4
        : xp >= 250 ? 3
        : xp >= 100 ? 2
        : 1;
    }

    function previousXP() {
      return resource.data.xp is int ? resource.data.xp : 0;
    }

    function previousLevel() {
      return resource.data.level is int
        ? resource.data.level
        : expectedLevelFromXP(previousXP());
    }

    function previousStreak() {
      return resource.data.streak is int ? resource.data.streak : 0;
    }

    function previousBestStreak() {
      return resource.data.bestStreak is int
        ? resource.data.bestStreak
        : previousStreak();
    }

    function expectedBestStreakAfterUpdate() {
      return request.resource.data.streak > previousBestStreak()
        ? request.resource.data.streak
        : previousBestStreak();
    }

    function isValidXPEventId(value) {
      return value is string
        && value.size() > 0
        && value.size() <= 160
        && value.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function xpEventPath(uid, eventId) {
      return /databases/$(db)/documents/users/$(uid)/xpEvents/$(eventId);
    }

    function hasOnlyUserProfileFields() {
      return request.resource.data.keys().hasOnly([
        'uid',
        'displayName',
        'email',
        'avatarEmoji',
        'ageGroup',
        'xp',
        'level',
        'levelTitle',
        'streak',
        'bestStreak',
        'lastActiveDate',
        'createdAt',
        'updatedAt',
        'lastXPGrantAt',
        'lastXPEventId'
      ]);
    }

    function hasRequiredUserProfileFields() {
      return request.resource.data.keys().hasAll([
        'uid',
        'displayName',
        'email',
        'avatarEmoji',
        'ageGroup',
        'xp',
        'level',
        'streak',
        'lastActiveDate'
      ]);
    }

    function isValidUserProfileShape(uid) {
      return hasOnlyUserProfileFields()
        && hasRequiredUserProfileFields()
        && request.resource.data.uid == uid
        && isNonEmptyString(request.resource.data.displayName, 40)
        && isNonEmptyString(request.resource.data.email, 254)
        && isValidAvatarEmoji(request.resource.data.avatarEmoji)
        && isValidAgeGroup(request.resource.data.ageGroup)
        && request.resource.data.xp is int
        && request.resource.data.xp >= 0
        && request.resource.data.xp <= 100000
        && request.resource.data.level is int
        && request.resource.data.level >= 1
        && request.resource.data.level <= 10
        && (
          !request.resource.data.keys().hasAny(['levelTitle'])
          || isValidLevelTitle(request.resource.data.levelTitle)
        )
        && request.resource.data.streak is int
        && request.resource.data.streak >= 0
        && request.resource.data.streak <= 3650
        && (
          !request.resource.data.keys().hasAny(['bestStreak'])
          || (
            request.resource.data.bestStreak is int
            && request.resource.data.bestStreak >= 0
            && request.resource.data.bestStreak <= 3650
          )
        )
        && isValidLastActiveDate(request.resource.data.lastActiveDate)
        && isOptionalTimestamp('createdAt')
        && isOptionalTimestamp('updatedAt')
        && isOptionalTimestamp('lastXPGrantAt')
        && (
          !request.resource.data.keys().hasAny(['lastXPEventId'])
          || isValidXPEventId(request.resource.data.lastXPEventId)
        );
    }

    function isValidUserProfileCreate(uid) {
      return isValidUserProfileShape(uid)
        && request.resource.data.xp == 0
        && request.resource.data.level == 1
        && request.resource.data.streak == 0
        && (
          !request.resource.data.keys().hasAny(['bestStreak'])
          || request.resource.data.bestStreak == 0
        )
        && !request.resource.data.keys().hasAny(['lastXPGrantAt'])
        && !request.resource.data.keys().hasAny(['lastXPEventId']);
    }

    function editableUserProfileFieldsChanged() {
      return changedKeys().hasOnly([
        'displayName',
        'avatarEmoji',
        'ageGroup',
        'updatedAt'
      ]);
    }

    function isValidDisplayNameUpdate() {
      return !changedKeys().hasAny(['displayName'])
        || isNonEmptyString(request.resource.data.displayName, 40);
    }

    function isValidAvatarEmojiUpdate() {
      return !changedKeys().hasAny(['avatarEmoji'])
        || isValidAvatarEmoji(request.resource.data.avatarEmoji);
    }

    function isValidAgeGroupUpdate() {
      return !changedKeys().hasAny(['ageGroup'])
        || isValidAgeGroup(request.resource.data.ageGroup);
    }

    function isValidUpdatedAtUpdate() {
      return !changedKeys().hasAny(['updatedAt'])
        || request.resource.data.updatedAt is timestamp;
    }

    function isValidEditableUserProfileUpdate() {
      return editableUserProfileFieldsChanged()
        && isValidDisplayNameUpdate()
        && isValidAvatarEmojiUpdate()
        && isValidAgeGroupUpdate()
        && isValidUpdatedAtUpdate();
    }

    function isValidXPGrantUserUpdate(uid) {
      let eventId = request.resource.data.lastXPEventId;
      let event = getAfter(xpEventPath(uid, eventId)).data;

      return changedKeys().hasOnly([
          'xp',
          'level',
          'levelTitle',
          'updatedAt',
          'lastXPGrantAt',
          'lastXPEventId'
        ])
        && isValidXPEventId(eventId)
        && !exists(xpEventPath(uid, eventId))
        && existsAfter(xpEventPath(uid, eventId))
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.lastXPGrantAt is timestamp
        && request.resource.data.xp is int
        && request.resource.data.xp >= 0
        && request.resource.data.xp <= 100000
        && request.resource.data.level is int
        && request.resource.data.level >= 1
        && request.resource.data.level <= 10
        && isValidLevelTitle(request.resource.data.levelTitle)
        && event.eventId == eventId
        && event.userId == uid
        && event.reason != 'achievement'
        && event.amount == request.resource.data.xp - previousXP()
        && event.previousXP == previousXP()
        && event.newXP == request.resource.data.xp
        && event.previousLevel == previousLevel()
        && event.newLevel == request.resource.data.level
        && event.levelTitle == request.resource.data.levelTitle
        && request.resource.data.xp == previousXP() + event.amount
        && request.resource.data.level == expectedLevelFromXP(request.resource.data.xp);
    }

    function isValidStreakUserUpdate() {
      return changedKeys().hasOnly([
          'streak',
          'bestStreak',
          'lastActiveDate',
          'updatedAt'
        ])
        && request.resource.data.streak is int
        && request.resource.data.streak >= 0
        && request.resource.data.streak <= 3650
        && request.resource.data.bestStreak is int
        && request.resource.data.bestStreak >= 0
        && request.resource.data.bestStreak <= 3650
        && (
          request.resource.data.streak == 1
          || request.resource.data.streak == previousStreak() + 1
        )
        && request.resource.data.bestStreak == expectedBestStreakAfterUpdate()
        && isValidLastActiveDate(request.resource.data.lastActiveDate)
        && request.resource.data.updatedAt is timestamp;
    }

    function isValidUserProfileUpdate(uid) {
      return isValidEditableUserProfileUpdate()
        || isValidXPGrantUserUpdate(uid)
        || isValidStreakUserUpdate();
    }

    function isValidXPReasonAmount(reason, amount) {
      return (
        reason == 'create_palace' && amount == 25
      ) || (
        reason == 'add_station' && amount == 10
      ) || (
        reason == 'complete_review' && amount == 20
      ) || (
        reason == 'perfect_review' && amount == 50
      ) || (
        reason == 'seven_day_streak' && amount == 100
      );
    }

    function hasOnlyXPEventFields() {
      return request.resource.data.keys().hasOnly([
        'eventId',
        'userId',
        'reason',
        'amount',
        'previousXP',
        'newXP',
        'previousLevel',
        'newLevel',
        'levelTitle',
        'leveledUp',
        'metadata',
        'createdAt'
      ]);
    }

    function hasValidXPEventBase(uid, eventId) {
      return hasOnlyXPEventFields()
        && request.resource.data.eventId == eventId
        && request.resource.data.userId == uid
        && isValidXPEventId(request.resource.data.eventId)
        && request.resource.data.reason is string
        && request.resource.data.amount is int
        && request.resource.data.amount > 0
        && request.resource.data.amount <= 500
        && isValidXPReasonAmount(
          request.resource.data.reason,
          request.resource.data.amount
        )
        && request.resource.data.previousXP is int
        && request.resource.data.previousXP >= 0
        && request.resource.data.newXP is int
        && request.resource.data.newXP == request.resource.data.previousXP + request.resource.data.amount
        && request.resource.data.newXP <= 100000
        && request.resource.data.previousLevel is int
        && request.resource.data.previousLevel >= 1
        && request.resource.data.previousLevel <= 10
        && request.resource.data.newLevel is int
        && request.resource.data.newLevel >= 1
        && request.resource.data.newLevel <= 10
        && request.resource.data.newLevel >= request.resource.data.previousLevel
        && request.resource.data.newLevel == expectedLevelFromXP(request.resource.data.newXP)
        && isValidLevelTitle(request.resource.data.levelTitle)
        && request.resource.data.leveledUp is bool
        && request.resource.data.metadata is map
        && request.resource.data.createdAt is timestamp;
    }

    function xpEventIsLinkedToUserUpdate(uid, eventId) {
      let userAfter = getAfter(/databases/$(db)/documents/users/$(uid)).data;

      return existsAfter(/databases/$(db)/documents/users/$(uid))
        && userAfter.lastXPEventId == eventId
        && userAfter.xp == request.resource.data.newXP
        && userAfter.level == request.resource.data.newLevel
        && userAfter.levelTitle == request.resource.data.levelTitle
        && userAfter.lastXPGrantAt is timestamp;
    }

    function isValidCreatePalaceXPEvent(uid) {
      let palaceId = request.resource.data.metadata.palaceId;

      return request.resource.data.reason == 'create_palace'
        && request.resource.data.amount == 25
        && palaceId is string
        && exists(/databases/$(db)/documents/users/$(uid)/palaces/$(palaceId));
    }

    function isValidAddStationXPEvent(uid) {
      let palaceId = request.resource.data.metadata.palaceId;
      let stationId = request.resource.data.metadata.stationId;

      return request.resource.data.reason == 'add_station'
        && request.resource.data.amount == 10
        && palaceId is string
        && stationId is string
        && exists(
          /databases/$(db)/documents/users/$(uid)/palaces/$(palaceId)/stations/$(stationId)
        );
    }

    function isValidReviewXPEvent(uid) {
      let palaceId = request.resource.data.metadata.palaceId;
      let sessionId = request.resource.data.metadata.sessionId;
      let review = get(
        /databases/$(db)/documents/users/$(uid)/palaces/$(palaceId)/reviewSessions/$(sessionId)
      ).data;

      return palaceId is string
        && sessionId is string
        && review.userId == uid
        && review.palaceId == palaceId
        && review.status == 'completed'
        && review.completedAt is timestamp
        && review.xpEarned is int
        && review.correctAnswers + review.incorrectAnswers == review.totalStations
        && (
          (
            request.resource.data.reason == 'complete_review'
            && request.resource.data.amount == 20
            && review.xpEarned >= 20
          )
          || (
            request.resource.data.reason == 'perfect_review'
            && request.resource.data.amount == 50
            && review.isPerfect == true
            && review.xpEarned == 70
          )
        );
    }

    function isValidSevenDayStreakXPEvent(uid) {
      return request.resource.data.reason == 'seven_day_streak'
        && request.resource.data.amount == 100
        && request.resource.data.metadata.date is string
        && request.resource.data.metadata.streak == 7
        && get(/databases/$(db)/documents/users/$(uid)).data.streak >= 7;
    }

    function isValidXPEventCreate(uid, eventId) {
      return hasValidXPEventBase(uid, eventId)
        && xpEventIsLinkedToUserUpdate(uid, eventId)
        && (
          isValidCreatePalaceXPEvent(uid)
          || isValidAddStationXPEvent(uid)
          || isValidReviewXPEvent(uid)
          || isValidSevenDayStreakXPEvent(uid)
        );
    }

    function isValidPalaceTemplateId(value) {
      return value in [
        'my-home',
        'magic-castle',
        'enchanted-forest',
        'space-station',
        'underwater-world',
        'dinosaur-island'
      ];
    }

    function hasOnlyPalaceFields() {
      return request.resource.data.keys().hasOnly([
        'userId',
        'name',
        'templateId',
        'stationCount',
        'createdAt',
        'updatedAt'
      ]);
    }

    function hasRequiredPalaceFields() {
      return request.resource.data.keys().hasAll([
        'userId',
        'name',
        'templateId',
        'stationCount',
        'createdAt'
      ]);
    }

    function isValidPalaceName(value) {
      return value is string && value.size() > 0 && value.size() <= 40;
    }

    function isValidPalaceStationCount(value) {
      return value is int && value >= 0 && value <= 20;
    }

    function isValidPalaceShape(uid) {
      return hasOnlyPalaceFields()
        && hasRequiredPalaceFields()
        && request.resource.data.userId == uid
        && isValidPalaceName(request.resource.data.name)
        && isValidPalaceTemplateId(request.resource.data.templateId)
        && isValidPalaceStationCount(request.resource.data.stationCount)
        && request.resource.data.createdAt is timestamp
        && isOptionalTimestamp('updatedAt');
    }

    function isValidPalaceCreate(uid) {
      return isValidPalaceShape(uid)
        && request.resource.data.stationCount == 0;
    }

    function onlyEditablePalaceFieldsChanged() {
      return changedKeys().hasOnly([
        'name',
        'stationCount',
        'updatedAt'
      ]);
    }

    function preservesImmutablePalaceFields() {
      return request.resource.data.userId == resource.data.userId
        && request.resource.data.templateId == resource.data.templateId
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function isValidPalaceStationCountTransition() {
      return request.resource.data.stationCount == resource.data.stationCount
        || (
          changedKeys().hasOnly([
            'stationCount',
            'updatedAt'
          ])
          && (
            request.resource.data.stationCount == resource.data.stationCount + 1
            || request.resource.data.stationCount == resource.data.stationCount - 1
          )
        );
    }

    function isValidPalaceUpdate(uid) {
      return isValidPalaceShape(uid)
        && resource.data.userId == uid
        && onlyEditablePalaceFieldsChanged()
        && preservesImmutablePalaceFields()
        && isValidPalaceStationCountTransition();
    }

    function hasValidOptionalImageUri() {
      return !request.resource.data.keys().hasAny(['imageUri'])
        || (
          request.resource.data.imageUri is string
          && request.resource.data.imageUri.size() <= 2048
          && request.resource.data.imageUri.matches('https://firebasestorage.googleapis.com/.*')
        );
    }

    function isValidStation(uid, palaceId) {
      return request.resource.data.keys().hasOnly([
        'id',
        'palaceId',
        'userId',
        'order',
        'emoji',
        'label',
        'memoryText',
        'imageUri',
        'createdAt',
        'updatedAt'
      ])
        && request.resource.data.userId == uid
        && request.resource.data.palaceId == palaceId
        && request.resource.data.order is int
        && request.resource.data.order >= 0
        && request.resource.data.order <= 20
        && request.resource.data.emoji is string
        && request.resource.data.emoji.size() > 0
        && request.resource.data.emoji.size() <= 16
        && request.resource.data.label is string
        && request.resource.data.label.size() > 0
        && request.resource.data.label.size() <= 40
        && request.resource.data.memoryText is string
        && request.resource.data.memoryText.size() <= 500
        && request.resource.data.createdAt is timestamp
        && isOptionalTimestamp('updatedAt')
        && hasValidOptionalImageUri();
    }

    function isValidReviewSessionCreate(uid, palaceId) {
      let palace = get(
        /databases/$(db)/documents/users/$(uid)/palaces/$(palaceId)
      ).data;

      return request.resource.data.keys().hasOnly([
          'palaceId',
          'userId',
          'startedAt',
          'completedAt',
          'totalStations',
          'correctAnswers',
          'incorrectAnswers',
          'xpEarned',
          'xpAppliedToUser',
          'xpAppliedAt',
          'isPerfect',
          'status',
          'updatedAt'
        ])
        && request.resource.data.userId == uid
        && request.resource.data.palaceId == palaceId
        && palace.userId == uid
        && palace.stationCount is int
        && request.resource.data.totalStations == palace.stationCount
        && request.resource.data.startedAt is timestamp
        && request.resource.data.completedAt == null
        && request.resource.data.totalStations is int
        && request.resource.data.totalStations >= 2
        && request.resource.data.totalStations <= 20
        && request.resource.data.correctAnswers == 0
        && request.resource.data.incorrectAnswers == 0
        && request.resource.data.xpEarned == 0
        && request.resource.data.xpAppliedToUser == false
        && (
          !request.resource.data.keys().hasAny(['xpAppliedAt'])
          || request.resource.data.xpAppliedAt == null
        )
        && (
          !request.resource.data.keys().hasAny(['isPerfect'])
          || request.resource.data.isPerfect == false
        )
        && request.resource.data.status == 'active'
        && isOptionalTimestamp('updatedAt');
    }

    function hasValidReviewXpAppliedFlag() {
      return !request.resource.data.keys().hasAny(['xpAppliedToUser'])
        || request.resource.data.xpAppliedToUser is bool;
    }

    function reviewCountersAreValid() {
      return request.resource.data.correctAnswers is int
        && request.resource.data.incorrectAnswers is int
        && request.resource.data.correctAnswers >= 0
        && request.resource.data.incorrectAnswers >= 0
        && request.resource.data.correctAnswers <= request.resource.data.totalStations
        && request.resource.data.incorrectAnswers <= request.resource.data.totalStations
        && request.resource.data.correctAnswers + request.resource.data.incorrectAnswers <= request.resource.data.totalStations;
    }

    function oneAnswerCounterTransition() {
      return (
          request.resource.data.correctAnswers == resource.data.correctAnswers + 1
          && request.resource.data.incorrectAnswers == resource.data.incorrectAnswers
        )
        || (
          request.resource.data.correctAnswers == resource.data.correctAnswers
          && request.resource.data.incorrectAnswers == resource.data.incorrectAnswers + 1
        )
        || (
          request.resource.data.correctAnswers == resource.data.correctAnswers
          && request.resource.data.incorrectAnswers == resource.data.incorrectAnswers
        )
        || (
          request.resource.data.correctAnswers == resource.data.correctAnswers + 1
          && request.resource.data.incorrectAnswers == resource.data.incorrectAnswers - 1
        )
        || (
          request.resource.data.correctAnswers == resource.data.correctAnswers - 1
          && request.resource.data.incorrectAnswers == resource.data.incorrectAnswers + 1
        );
    }

    function expectedReviewXpEarned() {
      return (
        request.resource.data.correctAnswers == request.resource.data.totalStations
        && request.resource.data.incorrectAnswers == 0
      ) ? 70 : 20;
    }

    function expectedReviewIsPerfect() {
      return request.resource.data.correctAnswers == request.resource.data.totalStations
        && request.resource.data.incorrectAnswers == 0;
    }

    function immutableReviewSessionFieldsArePreserved() {
      return resource.data.userId == uid
        && resource.data.palaceId == palaceId
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.palaceId == resource.data.palaceId
        && request.resource.data.startedAt == resource.data.startedAt
        && request.resource.data.totalStations == resource.data.totalStations;
    }

    function isUnsetOrNull(fieldName) {
      return !request.resource.data.keys().hasAny([fieldName])
        || request.resource.data[fieldName] == null;
    }

    function isUnsetOrFalse(fieldName) {
      return !request.resource.data.keys().hasAny([fieldName])
        || request.resource.data[fieldName] == false;
    }

    function isUnsetOrZero(fieldName) {
      return !request.resource.data.keys().hasAny([fieldName])
        || request.resource.data[fieldName] == 0;
    }

    function isValidActiveReviewAnswerUpdate(uid, palaceId) {
      return resource.data.userId == uid
        && resource.data.palaceId == palaceId
        && resource.data.status == 'active'
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.palaceId == resource.data.palaceId
        && request.resource.data.startedAt == resource.data.startedAt
        && request.resource.data.totalStations == resource.data.totalStations
        && request.resource.data.status == resource.data.status
        && changedKeys().hasOnly([
          'correctAnswers',
          'incorrectAnswers',
          'updatedAt'
        ])
        && reviewCountersAreValid()
        && oneAnswerCounterTransition()
        && request.resource.data.updatedAt is timestamp;
    }

    function isValidReviewCompletionUpdate(uid, palaceId) {
      return resource.data.status == 'active'
        && request.resource.data.status == 'completed'
        && changedKeys().hasOnly([
          'completedAt',
          'xpEarned',
          'xpAppliedToUser',
          'isPerfect',
          'status',
          'updatedAt'
        ])
        && reviewCountersAreValid()
        && request.resource.data.correctAnswers + request.resource.data.incorrectAnswers == request.resource.data.totalStations
        && request.resource.data.completedAt is timestamp
        && request.resource.data.xpEarned == expectedReviewXpEarned()
        && request.resource.data.xpAppliedToUser == false
        && request.resource.data.isPerfect == expectedReviewIsPerfect()
        && request.resource.data.updatedAt is timestamp;
    }

    function isValidReviewXPAppliedUpdate(uid, palaceId) {
      return resource.data.status == 'completed'
        && request.resource.data.status == 'completed'
        && changedKeys().hasOnly([
          'xpAppliedToUser',
          'xpAppliedAt',
          'updatedAt'
        ])
        && request.resource.data.xpAppliedToUser == true
        && request.resource.data.xpAppliedAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    function isValidRecordAnswerCounterUpdate(uid, palaceId) {
      return resource.data.userId == uid
        && resource.data.palaceId == palaceId
        && resource.data.status == 'active'
        && resource.data.totalStations is int
        && resource.data.totalStations >= 2
        && resource.data.totalStations <= 20
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.palaceId == resource.data.palaceId
        && request.resource.data.status == resource.data.status
        && request.resource.data.startedAt == resource.data.startedAt
        && request.resource.data.totalStations == resource.data.totalStations
        && request.resource.data.correctAnswers is int
        && request.resource.data.incorrectAnswers is int
        && request.resource.data.correctAnswers >= 0
        && request.resource.data.incorrectAnswers >= 0
        && request.resource.data.correctAnswers <= resource.data.totalStations
        && request.resource.data.incorrectAnswers <= resource.data.totalStations
        && request.resource.data.correctAnswers + request.resource.data.incorrectAnswers <= resource.data.totalStations
        && (
          (
            request.resource.data.correctAnswers == resource.data.correctAnswers + 1
            && request.resource.data.incorrectAnswers == resource.data.incorrectAnswers
          )
          || (
            request.resource.data.correctAnswers == resource.data.correctAnswers
            && request.resource.data.incorrectAnswers == resource.data.incorrectAnswers + 1
          )
          || (
            request.resource.data.correctAnswers == resource.data.correctAnswers
            && request.resource.data.incorrectAnswers == resource.data.incorrectAnswers
          )
          || (
            request.resource.data.correctAnswers == resource.data.correctAnswers + 1
            && request.resource.data.incorrectAnswers == resource.data.incorrectAnswers - 1
          )
          || (
            request.resource.data.correctAnswers == resource.data.correctAnswers - 1
            && request.resource.data.incorrectAnswers == resource.data.incorrectAnswers + 1
          )
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'correctAnswers',
          'incorrectAnswers',
          'updatedAt'
        ])
        && request.resource.data.updatedAt is timestamp;
    }
    function isValidCompleteReviewUpdate(uid, palaceId) {
      return resource.data.userId == uid
        && resource.data.palaceId == palaceId
        && resource.data.status == 'active'
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.palaceId == resource.data.palaceId
        && request.resource.data.startedAt == resource.data.startedAt
        && request.resource.data.totalStations == resource.data.totalStations
        && request.resource.data.correctAnswers == resource.data.correctAnswers
        && request.resource.data.incorrectAnswers == resource.data.incorrectAnswers
        && request.resource.data.status == 'completed'
        && request.resource.data.completedAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.xpEarned is int
        && (
          request.resource.data.xpEarned == 20
          || request.resource.data.xpEarned == 70
        )
        && request.resource.data.xpAppliedToUser == false
        && request.resource.data.isPerfect is bool
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'completedAt',
          'xpEarned',
          'xpAppliedToUser',
          'isPerfect',
          'status',
          'updatedAt'
        ]);
    }

    function isValidReviewSessionUpdate(uid, palaceId) {
      return request.resource.data.keys().hasOnly([
          'palaceId',
          'userId',
          'startedAt',
          'completedAt',
          'totalStations',
          'correctAnswers',
          'incorrectAnswers',
          'xpEarned',
          'xpAppliedToUser',
          'xpAppliedAt',
          'isPerfect',
          'status',
          'updatedAt'
        ])
        && immutableReviewSessionFieldsArePreserved()
        && hasValidReviewXpAppliedFlag()
        && (
          isValidActiveReviewAnswerUpdate(uid, palaceId)
          || isValidReviewCompletionUpdate(uid, palaceId)
          || isValidReviewXPAppliedUpdate(uid, palaceId)
        );
    }

    function reviewSessionPath(uid, palaceId, sessionId) {
      return /databases/$(db)/documents/users/$(uid)/palaces/$(palaceId)/reviewSessions/$(sessionId);
    }

    function stationPath(uid, palaceId, stationId) {
      return /databases/$(db)/documents/users/$(uid)/palaces/$(palaceId)/stations/$(stationId);
    }

    function isValidReviewAnswer(uid, palaceId, sessionId, answerId) {
      return request.resource.data.keys().hasOnly([
          'sessionId',
          'stationId',
          'correct',
          'answeredAt'
        ])
        && request.resource.data.sessionId == sessionId
        && request.resource.data.stationId is string
        && request.resource.data.stationId.size() > 0
        && answerId == request.resource.data.stationId
        && request.resource.data.correct is bool
        && (
          !request.resource.data.keys().hasAny(['answeredAt'])
          || request.resource.data.answeredAt is timestamp
        );
    }

    function isValidAchievementWrite(uid, achievementId) {
      return request.resource.data.keys().hasOnly([
          'id',
          'achievementId',
          'title',
          'description',
          'emoji',
          'xpReward',
          'earnedAt',
          'createdAt',
          'unlockedAt',
          'triggerType',
          'xpEventId',
          'metadata'
        ])
        && (
          !request.resource.data.keys().hasAny(['id'])
          || request.resource.data.id == achievementId
        )
        && (
          !request.resource.data.keys().hasAny(['achievementId'])
          || request.resource.data.achievementId == achievementId
        )
        && (
          !request.resource.data.keys().hasAny(['title'])
          || isNonEmptyString(request.resource.data.title, 80)
        )
        && (
          !request.resource.data.keys().hasAny(['description'])
          || request.resource.data.description is string
        )
        && (
          !request.resource.data.keys().hasAny(['emoji'])
          || isValidAvatarEmoji(request.resource.data.emoji)
        )
        && (
          !request.resource.data.keys().hasAny(['xpReward'])
          || (
            request.resource.data.xpReward is int
            && request.resource.data.xpReward >= 0
            && request.resource.data.xpReward <= 500
          )
        )
        && (
          !request.resource.data.keys().hasAny(['triggerType'])
          || request.resource.data.triggerType is string
        )
        && (
          !request.resource.data.keys().hasAny(['xpEventId'])
          || isValidXPEventId(request.resource.data.xpEventId)
        )
        && (
          !request.resource.data.keys().hasAny(['metadata'])
          || request.resource.data.metadata is map
        )
        && isOptionalTimestamp('earnedAt')
        && isOptionalTimestamp('createdAt')
        && isOptionalTimestamp('unlockedAt');
    }


    function isValidStatsInt(value, maxValue) {
      return value is int && value >= 0 && value <= maxValue;
    }

    function isValidStatsSummaryShape() {
      return request.resource.data.keys().hasOnly([
          'totalPalaces',
          'totalStations',
          'totalReviewSessions',
          'totalPerfectReviews',
          'totalCorrectAnswers',
          'totalIncorrectAnswers',
          'stationsWithImages',
          'usedTemplateIds',
          'reviewDateStrings',
          'fastestReviewSeconds',
          'updatedAt',
          'rebuiltAt'
        ])
        && request.resource.data.keys().hasAll([
          'totalPalaces',
          'totalStations',
          'totalReviewSessions',
          'totalPerfectReviews',
          'totalCorrectAnswers',
          'totalIncorrectAnswers',
          'stationsWithImages',
          'usedTemplateIds',
          'reviewDateStrings',
          'fastestReviewSeconds',
          'updatedAt'
        ])
        && isValidStatsInt(request.resource.data.totalPalaces, 1000)
        && isValidStatsInt(request.resource.data.totalStations, 20000)
        && isValidStatsInt(request.resource.data.totalReviewSessions, 100000)
        && isValidStatsInt(request.resource.data.totalPerfectReviews, 100000)
        && request.resource.data.totalPerfectReviews <= request.resource.data.totalReviewSessions
        && isValidStatsInt(request.resource.data.totalCorrectAnswers, 2000000)
        && isValidStatsInt(request.resource.data.totalIncorrectAnswers, 2000000)
        && isValidStatsInt(request.resource.data.stationsWithImages, 20000)
        && request.resource.data.stationsWithImages <= request.resource.data.totalStations
        && request.resource.data.usedTemplateIds is list
        && request.resource.data.usedTemplateIds.size() <= 6
        && request.resource.data.reviewDateStrings is list
        && request.resource.data.reviewDateStrings.size() <= 5000
        && (
          request.resource.data.fastestReviewSeconds == null
          || isValidStatsInt(request.resource.data.fastestReviewSeconds, 86400)
        )
        && request.resource.data.updatedAt is timestamp
        && isOptionalTimestamp('rebuiltAt');
    }

    match /users/{uid} {
      allow read: if isOwner(uid);

      allow create: if isOwner(uid)
        && isValidUserProfileCreate(uid);

      allow update: if isOwner(uid)
        && isValidUserProfileUpdate(uid);

      allow delete: if false;

      match /stats/{statsId} {
        allow read: if isOwner(uid);

        allow create, update: if isOwner(uid)
          && statsId == 'summary'
          && isValidStatsSummaryShape();

        allow delete: if false;
      }

      match /xpEvents/{eventId} {
        allow read: if isOwner(uid);

        allow create: if isOwner(uid)
          && !exists(xpEventPath(uid, eventId))
          && isValidXPEventCreate(uid, eventId);

        allow update, delete: if false;
      }

      match /achievements/{achievementId} {
        allow read: if isOwner(uid);

        allow create, update: if isOwner(uid)
          && isValidAchievementWrite(uid, achievementId);

        allow delete: if false;
      }

      match /palaces/{palaceId} {
        allow read: if isOwner(uid);

        allow create: if isOwner(uid)
          && isValidPalaceCreate(uid);

        allow update: if isOwner(uid)
          && isValidPalaceUpdate(uid);

        allow delete: if isOwner(uid)
          && resource.data.userId == uid;

        match /stations/{stationId} {
          allow read: if isOwner(uid);

          allow create: if isOwner(uid)
            && isValidStation(uid, palaceId);

          allow update: if isOwner(uid)
            && resource.data.userId == uid
            && resource.data.palaceId == palaceId
            && isValidStation(uid, palaceId);

          allow delete: if isOwner(uid)
            && resource.data.userId == uid
            && resource.data.palaceId == palaceId;
        }

        match /reviewSessions/{sessionId} {
          allow read: if isOwner(uid);

          allow create: if isOwner(uid)
            && isValidReviewSessionCreate(uid, palaceId);

          allow update: if isOwner(uid)
            && (
              isValidRecordAnswerCounterUpdate(uid, palaceId)
              || isValidCompleteReviewUpdate(uid, palaceId)
              || isValidReviewXPAppliedUpdate(uid, palaceId)
              || isValidReviewSessionUpdate(uid, palaceId)
            );

          allow delete: if isOwner(uid)
            && resource.data.userId == uid
            && resource.data.palaceId == palaceId;

          match /answers/{answerId} {
            allow read: if isOwner(uid);

            allow create, update: if isOwner(uid)
              && isValidReviewAnswer(uid, palaceId, sessionId, answerId);

            allow delete: if isOwner(uid);
          }
        }
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
