{
  "expo": {
    "name": "LociLand",
    "slug": "lociland",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "lociland",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFBF0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.angelpeka.lociland"
    },
    "android": {
      "package": "com.angelpeka.lociland",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFD93D"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-web-browser",
      "expo-video",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#FFFBF0"
        }
      ]
    ]
  }
}